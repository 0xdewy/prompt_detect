# Prompt Detective API Configuration
# Copy this file to .env and update the values

# ============================================
# REQUIRED: Wallet Configuration
# ============================================
# Your EVM wallet address for receiving payments on Base network
# Format: 0x followed by 40 hexadecimal characters
WALLET_ADDRESS=0xYourWalletAddressHere

# ============================================
# x402 Payment Configuration
# ============================================
# Facilitator URL (CDP for mainnet)
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Network identifier (CAIP-2 format)
# Base mainnet: eip155:8453
# Base Sepolia testnet: eip155:84532
NETWORK=eip155:8453

# Price per prediction (must include $ prefix)
PRICE=$0.01

# ============================================
# Server Configuration
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
APP_THREADS=2

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Model Configuration
# ============================================
# Path to existing prompt_detective models
# These should be copied from the original codebase
MODEL_DIR=../prompt_detective/models/checkpoints

# ============================================
# Security Configuration
# ============================================
# CORS origins (comma-separated)
# For production: https://your-frontend-domain.com,https://www.your-frontend-domain.com
CORS_ORIGINS=*

# Frontend API key for protected endpoints (upload_files)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FRONTEND_API_KEY=your_frontend_api_key_here

# Enable/disable x402 payment verification
X402_ENABLED=true

# Maximum input length (characters)
MAX_INPUT_LENGTH=10000

# ============================================
# CDP API Keys (Optional)
# ============================================
# If using CDP facilitator with advanced features
# CDP_API_KEY=your_cdp_api_key
# CDP_API_SECRET=your_cdp_api_secret

# ============================================
# Development/Testing
# ============================================
# Set to "development" for debug mode
ENVIRONMENT=production

# Mock mode (use fake predictions for testing)
# USE_MOCK=false